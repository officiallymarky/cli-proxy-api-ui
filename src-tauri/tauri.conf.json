{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI Proxy API UI",
  "version": "0.1.5",
  "identifier": "com.cliproxyapi.ui",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CLI Proxy API UI",
        "label": "main",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all",
    "category": "DeveloperTool"
  }
}
